{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "rootDir": "src",
    "paths": {
      "*": ["./*"],
      "work-shared/*": ["../shared/*"]
    },
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "src/webview",
    "scripts",
    "src-archive*",
    "webview-ui-archive*"
  ]
}
